TOKEN=
MODEL_PATH_ES=models/vosk-model-small-es-0.42
MODEL_PATH_EN=models/vosk-model-small-en-us-0.15
AUDIO_DIR=audio/
YT_DLP_PATH=yt-dlp
# bgutil PO Token provider (https://github.com/Brainicism/bgutil-ytdlp-pot-provider)
# Required to bypass YouTube's "Sign in to confirm you're not a bot" check.
# Leave empty to disable.
YT_DLP_POT_BASE_URL=http://127.0.0.1:4416

# Guild IDs where slash commands register instantly (comma-separated).
# Leave empty to register commands globally (may take up to 1h to propagate).
# Example: DEBUG_GUILD_IDS=451575911704428554,523359466528440320
DEBUG_GUILD_IDS=

# PostHog product analytics (leave POSTHOG_API_KEY empty to disable)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# HTTP API for telegram bridge bot
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET=

# Google Gemini API (https://aistudio.google.com/apikey)
# Free tier: 10 RPM, 250 RPD en gemini-2.5-flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Ruta donde se persiste la memoria conversacional de /indio (JSON).
# Sobrevive reinicios del servicio. Default: data/indio_memory.json
INDIO_MEMORY_PATH=data/indio_memory.json

# Ruta al archivo JSON con datos estáticos de usuarios (traits, anécdotas, etc.).
# Default: data/users.json. Si no existe o falla, users.py usa el fallback hardcodeado.
USERS_PATH=data/users.json

# Relay al userbot: si está seteado, /indio publica la respuesta a través del
# userbot (cuenta de usuario real) en vez del bot vapls. URL debe apuntar al
# endpoint POST /say expuesto por userbot/bot.py. El secret debe coincidir
# con RELAY_SECRET del userbot. Vacío = la respuesta sale del bot vapls.
INDIO_RELAY_URL=http://127.0.0.1:8081/say
INDIO_RELAY_SECRET=
INDIO_RELAY_TIMEOUT=10

# Voice-reply recording: cuando /play-audio termina de reproducir un audio
# de Telegram, el bot le pide al userbot que grabe hasta N segundos del
# canal de voz y le mande el OGG resultante al puente de Telegram. Vacío =
# desactivado. Apunta al endpoint POST /record del userbot.
USERBOT_RECORD_URL=http://127.0.0.1:8081/record
USERBOT_RECORD_SECRET=
USERBOT_RECORD_DEFAULT_DURATION=20
USERBOT_RECORD_TRIGGER_TIMEOUT=5

# Segundos de inactividad en voz (ni reproduciendo ni pausado) antes de
# que el bot se desconecte solo del canal. 0 desactiva el comportamiento
# en la práctica si lo seteás muy alto; default = 60.
VOICE_IDLE_TIMEOUT_SECONDS=60


# Hugging Face Inference API for /generarimagen (free tier).
# Sign up at huggingface.co → Settings → Access Tokens → New token (read).
HUGGINGFACE_API_TOKEN=

# Cloudflare Workers AI for free image-to-image/editing.
# Sign up at cloudflare.com (free tier, no credit card required).
# Go to Workers & Pages -> Overview -> find Account ID on the right.
# Go to My Profile -> API Tokens -> Create Token -> "Workers AI" template.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Feedback inline de calidad del ASR -----------------------------------
# 1 de cada N transcripciones de voz recibe reacciones 👍/❌ en el mensaje
# de transcripción para que los usuarios marquen falsos positivos del
# wake-word o errores groseros del ASR. 👍 no loggea nada; ❌ appendea una
# línea al JSONL para debug offline.
DECIFRAR_FEEDBACK_ENABLED=true
DECIFRAR_FEEDBACK_SAMPLE_RATE=3
DECIFRAR_FEEDBACK_TIMEOUT_MINUTES=60
DECIFRAR_FALSE_POSITIVES_LOG_PATH=data/false_positives.jsonl

# Discord user ID of the bot owner. Used to gate owner-only commands like
# /actividad for the MMR ranking system.
OWNER_ID=211354006805676032

# Discord user ID of the userbot (Indio). The bot excludes this ID from
# voice channel occupancy counts so the Indio's presence doesn't trigger
# or prolong MMR activities meant for at least 2 human users.
USERBOT_USER_ID=519594605520486428

# Activity/MMR tracking database for the ranking system.
# Path is relative to the working directory where bot.py is run.
ACTIVITY_DB_PATH=data/activity.db

# GitHub Issues for /sugerencias (leave GITHUB_TOKEN empty for local-only)
# Create a token at https://github.com/settings/tokens with "issues: write" scope.
GITHUB_TOKEN=
GITHUB_REPO=dilelu94/VaPls-Discord-Bot
GITHUB_ISSUE_LABEL=sugerencia

# --- Israel alerts (Tzevaadom WebSocket) -------------------------------------
# Enable real-time rocket/missile alert monitoring. Connects to the community
# Tzevaadom WebSocket (no geo-blocking, no auth). Requires a channel ID where
# alerts will be posted.
ISRAEL_ALERTS_ENABLED=false
ISRAEL_ALERTS_CHANNEL_ID=1490008278275461280
