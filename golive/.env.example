# Discord user account token for the GoLive userbot.
GOLIVE_TOKEN=your-token-here

# Local HTTP relay (main bot POSTs /stream here).
GOLIVE_RELAY_HOST=127.0.0.1
GOLIVE_RELAY_PORT=8082
GOLIVE_RELAY_SECRET=vapls-golive-shared-secret

# Optional: restrict to specific guild IDs (comma-separated).
GOLIVE_GUILD_ALLOWLIST=

LOG_LEVEL=INFO

# Spread each frame's RTP packets across 75% of the frame interval instead of
# bursting them, reducing freezes from dropped packet bursts.
STREAM_PACKET_PACE=0.75
