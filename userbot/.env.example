# Discord user account token. Get it from a logged-in Discord browser
# session: DevTools (F12) → Network tab → reload → click any /api/v9/...
# request → Headers → "authorization". Never share or commit this value.
USER_TOKEN=your-user-token-here

# Spanish VOSK model path. Defaults to the main bot's models dir.
MODEL_PATH_ES=/home/ubuntu/vapls-discord-bot/models/vosk-model-small-es-0.42

# Optional: restrict the userbot to specific guild IDs (comma-separated).
# Leave empty to listen in every guild the user is a member of.
GUILD_ALLOWLIST=

# Optional: skip transcribing audio from these user IDs (comma-separated).
# Recommended: include the main bot's user ID so it doesn't try to
# transcribe its own music playback.
IGNORE_USER_IDS=

# Optional: text channel name where transcripts will be posted by the
# user account. Leave empty to log to stdout only.
TRANSCRIPT_CHANNEL_NAME=

# Optional HTTP forward to the main bot's apiServer for downstream
# handling (keyword triggers, analytics). Disabled by default.
ENABLE_HTTP_FORWARD=false
BOT_API_BASE=http://127.0.0.1:8080
BOT_API_SECRET=

LOG_LEVEL=INFO
