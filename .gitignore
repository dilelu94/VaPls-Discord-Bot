# Discord Bot
.env
*.pyc
__pycache__/

# Audio files (as requested)
audio/*
!audio/.gitkeep

# Persisted runtime data (e.g. /indio conversation memory)
data/

# Vosk Models (too large for GitHub)
models/*
!models/.gitkeep

# Internal tools
.planning
*.zip
*.log
cookies.txt
ssh-key*.key

# Mapeo de API keys de Gemini a sus dueños (vive en el server, contiene secretos)
gemini_keys.json

# Python / tests
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/

# Local sync config (contains server-specific paths/hosts)
lsyncd*.lua
lsyncd*.service
lsyncd.status

# Cached image attachments for image-to-image
image_cache/*
!image_cache/.gitkeep

# Gemini Playwright Gmail session authentication state
gemini_auth.json

# One-off scripts (not part of the project)
setup_gemini_auto.py
setup_gemini_session.py
dump_elements.py
test_app_url.py
test_app_url_headful.py

